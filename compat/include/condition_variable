#ifndef AC6_RLOTTIE_COMPAT_CONDITION_VARIABLE
#define AC6_RLOTTIE_COMPAT_CONDITION_VARIABLE

/*
 * Keil AC6 裸机 libc++ 没有 std::condition_variable。
 *
 * rlottie 的部分缓存/栅格代码会保留 condition_variable 成员或调用。
 * 当前移植关闭了线程和缓存路径，因此这里只提供空操作占位，保证类型存在。
 */

#include <mutex>

namespace std {

class condition_variable {
public:
    /* 单线程构建不需要真实唤醒。 */
    void notify_one() {}

    template <typename Lock>
    /* 单线程构建不允许阻塞等待，否则会卡住主循环。 */
    void wait(Lock &) {}
};

} // namespace std

#endif
